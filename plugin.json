{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-agent-claude-gui",
  "name": {
    "en": "Claude GUI",
    "ko": "Claude GUI"
  },
  "version": "0.0.1",
  "description": {
    "en": "When claude (Claude Code CLI) runs in a terminal, a GUI entry appears in the panel statusbar; clicking it opens a bubble-UI overlay showing the conversation and active subagents in real time.",
    "ko": "\ud130\ubbf8\ub110\uc5d0\uc11c claude(Claude Code CLI)\uac00 \uc2e4\ud589\ub418\uba74 \ud328\ub110 \uc0c1\ud0dc\ubc14\uc5d0 GUI \ud56d\ubaa9\uc774 \ub728\uace0, \ub204\ub974\uba74 \ub300\ud654\ub97c \ubc84\ube14 UI\ub85c \ubcf4\uc5ec\uc8fc\ub294 \uc624\ubc84\ub808\uc774\uac00 \uc5f4\ub9b0\ub2e4. \ud65c\uc131 \uc138\uc158\uacfc \uc11c\ube0c\uc5d0\uc774\uc804\ud2b8\ub97c \uc2e4\uc2dc\uac04 \ud45c\uc2dc."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "ui:statusbar",
    "ui:overlay:pane",
    "commands",
    "terminal",
    "terminal:read",
    "terminal:write",
    "fs:read"
  ],
  "contributes": {
    "commands": [
      {
        "name": "toggle",
        "title": {
          "en": "Toggle Claude GUI",
          "ko": "Claude GUI \ucf1c\uae30/\ub044\uae30"
        }
      },
      {
        "name": "open",
        "title": {
          "en": "Open Claude GUI",
          "ko": "Claude GUI \uc5f4\uae30"
        }
      },
      {
        "name": "close",
        "title": {
          "en": "Close Claude GUI",
          "ko": "Claude GUI \ub2eb\uae30"
        }
      },
      {
        "name": "send",
        "title": {
          "en": "Send input (returns queue status)",
          "ko": "\uc785\ub825 \uc804\uc1a1(\ud050 \uc0c1\ud0dc \ubc18\ud658)"
        }
      },
      {
        "name": "focus",
        "title": {
          "en": "Focus GUI input box",
          "ko": "GUI \uc785\ub825\ucc3d \ud3ec\ucee4\uc2a4(\ud654\uba74 \uc774\ub3d9)"
        }
      },
      {
        "name": "type",
        "title": {
          "en": "Type into GUI input box + Enter",
          "ko": "GUI \uc785\ub825\ucc3d\uc5d0 \uc785\ub825+Enter"
        }
      },
      {
        "name": "queue",
        "title": {
          "en": "Get input queue snapshot",
          "ko": "\uc785\ub825 \ud050 \uc2a4\ub0c5\uc0f7 \uc870\ud68c"
        }
      },
      {
        "name": "state",
        "title": {
          "en": "Get overlay render state (e2e)",
          "ko": "\uc624\ubc84\ub808\uc774 \ub80c\ub354 \uc0c1\ud0dc \uc870\ud68c(e2e)"
        }
      }
    ],
    "nodes": [
      {
        "id": "input",
        "description": {
          "ko": "claude \uc785\ub825\ucc3d",
          "en": "claude input box"
        }
      },
      {
        "id": "send",
        "description": {
          "ko": "\uc785\ub825 \uc804\uc1a1 \ubc84\ud2bc",
          "en": "send button"
        }
      },
      {
        "id": "close",
        "description": {
          "ko": "\uc624\ubc84\ub808\uc774 \ub2eb\uae30 \ubc84\ud2bc",
          "en": "close overlay button"
        }
      },
      {
        "id": "verbose",
        "description": {
          "ko": "thinking \ud45c\uc2dc/\uc228\uae40 \ud1a0\uae00",
          "en": "thinking verbose toggle"
        }
      },
      {
        "id": "session",
        "description": {
          "ko": "\uc138\uc158 id \uce69(\ud074\ub9ad \ubcf5\uc0ac)",
          "en": "session id chip (click to copy)"
        }
      },
      {
        "id": "msg",
        "description": {
          "ko": "\uc0ac\uc6a9\uc790 \uba54\uc2dc\uc9c0 \ud589(\uc548\uc815\ud0a4=\uba54\uc2dc\uc9c0 uuid)",
          "en": "user message row (key = message uuid)"
        }
      },
      {
        "id": "agent",
        "description": {
          "ko": "\uc11c\ube0c\uc5d0\uc774\uc804\ud2b8 \ud328\ub110 \ud5e4\ub354(\uc548\uc815\ud0a4=agent id)",
          "en": "subagent panel header (key = agent id)"
        }
      }
    ]
  }
}
